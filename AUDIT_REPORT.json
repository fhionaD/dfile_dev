    "default_query_config": {
      "staleTime": "60_000 (60 seconds - data is fresh for 1 minute)",
      "retry": "1 (retry failed queries once)",
      "refetchOnWindowFocus": "false (no refetch when window regains focus)"
    },
    "auth_token_attachment": {
      "location": "src/lib/api.ts (Axios instance)",
      "mechanism": "Request interceptor attaches 'Authorization: Bearer <token>' header",
      "token_source": "localStorage.dfile_token (retrieved on every request)",
      "skip_condition": "skipAuthHeader=true or request is /auth/login",
      "deletion_on_logout": "NOT automatic - logout() in auth-context clears localStorage but does NOT call queryClient.clear()",
      "implication": "Stale queries may remain in cache post-logout; full cache clear requires browser refresh or explicit queryClient.clear() call"
    },
    "logout_behavior": {
      "auth_context_logout": "src/contexts/auth-context.tsx",
      "steps": [
        "1. Set isLoggingOut=true (show spinner)",
        "2. setTimeout 800ms (allow UI update)",
        "3. Clear user/token state",
        "4. Remove localStorage entries: 'dfile_user', 'dfile_token'",
        "5. Set isLoggingOut=false",
        "Note: queryClient NOT cleared; stale data remains accessible if cache accessed post-logout"
      ],
      "global_error_handling": "If GET /api/auth/me returns 401/403 during session init, logout() is called automatically"
    },
    "global_error_interceptor": {
      "location": "src/lib/api.ts response interceptor",
      "behaviors": [
        "409 Duplicate detected → Sonner toast + global error banner",
        "Network error → throttled global error banner (45sec cooldown) + Sonner warning",
        "4xx/5xx → global error banner with request URL and error message",
        "suppressGlobalError config option → skips banner for specific mutations (e.g., archive operations show Sonner toast instead)"
      ]
