  "section_2_api_endpoints": {
    "description": "All HTTP endpoints with methods, error responses, validation, and authorization",
    "controllers": [
      {
        "controller": "AssetsController",
        "route": "api/assets",
        "base_authorization": "[Authorize]",
        "endpoints": [
          {
            "method": "GET",
            "path": "/api/assets",
            "queryParams": {
              "showArchived": "bool, default false",
              "includeDisposed": "bool, default false",
              "page": "int?, null = single request (no pagination), 1+ for paging",
              "pageSize": "int, default 25, max 200",
              "q": "string?, search term across AssetName, AssetCode, TagNumber, Id, Model, SerialNumber",
              "status": "string?, filter by lifecycle status label",
              "category": "string?, filter by category name"
            },
            "authorization": "[RequirePermission('Assets', 'CanView')] OR User.IsInRole('Maintenance')",
            "responses": {
              "200_OK": {
                "paginated": "{ totalCount, totalPages, page, pageSize, data: Asset[] }",
                "unpaginated": "Asset[]"
              },
              "403_Forbidden": "{ message: 'You do not have permission to view assets.' }"
            }
          },
          {
            "method": "GET",
            "path": "/api/assets/summary",
            "authorization": "[RequirePermission('Assets', 'CanView')] OR User.IsInRole('Maintenance')",
            "responses": {
              "200_OK": "{ TotalAssets, UnallocatedAssets, OriginalPortfolioValue, CurrentBookValue }"
            }
          },
          {
            "method": "GET",
            "path": "/api/assets/available-for-allocation",
            "authorization": "[RequirePermission('Assets', 'CanView')] OR User.IsInRole('Maintenance')",
            "responses": {
              "200_OK": "Asset[] (only Registered or InUse status without active allocations)"
            }
          },
          {
            "method": "GET",
            "path": "/api/assets/{id}",
            "authorization": "[RequirePermission('Assets', 'CanView')] OR User.IsInRole('Maintenance')",
            "responses": {
              "200_OK": "AssetResponseDto",
              "404_NotFound": "{ message: 'Asset not found.' }"
            }
          },
          {
            "method": "POST",
            "path": "/api/assets",
            "body": "CreateAssetDto",
            "authorization": "[RequirePermissionOrRoles('Assets', 'CanCreate', UserRoleConstants.Finance)]",
            "validation": [
              "PurchaseDate cannot be in future (400)",
              "CategoryId must exist and not archived (400)",
              "SerialNumber must be unique per tenant (409 Conflict)",
              "UsefulLifeYears required and used in depreciation calc"
            ],
            "special_workflow": "If ReplacementMaintenanceRecordId provided, calls IMaintenanceReplacementRegistrationService to register replacement asset from maintenance workflow",
            "responses": {
              "201_Created": "AssetResponseDto",
              "400_BadRequest": "[message: 'Invalid CategoryId.' | 'Category is archived' | 'Purchase date in future' | 'Serial Number exists']",
              "409_Conflict": "{ message: 'Serial Number already exists.' }",
              "403_Forbidden": "You do not have permission"
            },
            "audit_log": "Action='Create', EntityType='Asset', Module='Asset Management', includes old/new values"
          },
          {
            "method": "PUT",
            "path": "/api/assets/{id}",
            "body": "UpdateAssetDto",
            "authorization": "[RequirePermission('Assets', 'CanEdit')]",
            "validation": [
              "Concurrency check via RowVersion (DbUpdateConcurrencyException → 409)",
              "Disposed assets cannot transition back to active (400)",
              "CategoryId must exist and not archived (400)",
              "SerialNumber unique per tenant (409 on duplicate)"
            ],
            "field_restrictions": [
              "Financial fields (AcquisitionCost, UsefulLifeYears, PurchasePrice, ResidualValue, CurrentBookValue) only writable by Admin, Finance, or Super Admin roles"
            ],
            "responses": {
              "204_NoContent": "Success",
              "400_BadRequest": "[message: various validation errors]",
              "404_NotFound": "Asset not found",
              "409_Conflict": "{ message: 'Concurrency exception' | 'Serial Number exists' }"
            }
          },
          {
            "method": "PUT",
            "path": "/api/assets/{id}/financial",
            "body": "UpdateAssetFinancialDto",
            "authorization": "[RequirePermission('Assets', 'CanEdit')]",
            "fields_updated": [
              "PurchasePrice, AcquisitionCost, UsefulLifeYears, ResidualValue, CurrentBookValue, MonthlyDepreciation"
            ],
            "responses": {
              "204_NoContent": "Success"
            }
          }
        ]
      },
