              "200_OK": "{ token: JWT, user: UserResponseDto with role }",
              "400_BadRequest": "{ message: 'Email and password required' }",
              "401_Unauthorized": "{ message: 'Invalid credentials' | 'Tenant inactive' }",
              "500_InternalServerError": "Unexpected error"
            }
          },
          {
            "method": "GET",
            "path": "/api/auth/me",
            "authorization": "[Authorize]",
            "responses": {
              "200_OK": "UserResponseDto with permissions",
              "401_Unauthorized": "Token invalid or expired"
            }
          },
          {
            "method": "POST",
            "path": "/api/auth/register",
            "body": "RegisterDto { email, roleTemplateId, tenantId? }",
            "authorization": "[Authorize(Roles = 'Super Admin,Admin')]",
            "validation": [
              "Email not already in use (400)",
              "RoleTemplate exists and not archived (400)",
              "Super Admin can assign to any tenant; Admin only own tenant (400 if violated)"
            ],
            "responses": {
              "201_Created": "{ userId, email, role }",
              "400_BadRequest": "Validation errors"
            }
          }
        ]
      }
    ],
    "error_handling_patterns": {
      "400_BadRequest": "Input validation failures (invalid state, constraint violations)",
      "401_Unauthorized": "Missing/invalid token or credentials",
      "403_Forbidden": "Authorization check failed (permission or role mismatch)",
      "404_NotFound": "Resource not found or tenant isolation prevents access",
      "409_Conflict": "Concurrency conflict (RowVersion mismatch) OR duplicate/constraint violation (serial number, email, etc.)",
      "500_InternalServerError": "Unexpected runtime error"
    }
  },

  "section_3_frontend_hooks": {
    "description": "TanStack Query hooks in src/hooks/ with queryKey structure, endpoints, and cache invalidation",
    "hook_files": [
      {
        "file": "use-assets.ts",
        "exports": [
          {
            "name": "useAssetsPaged",
            "queryKey": "['assets', 'paged', showArchived, page, pageSize, filters.q, filters.status, filters.category, filters.includeDisposed]",
            "endpoint": "GET /api/assets (with params)",
            "options": "placeholderData: keepPreviousData",
            "error_handling": "axios errors handled by global interceptor"
          },
          {
            "name": "useAssets",
            "queryKey": "['assets', showArchived, includeDisposed]",
            "endpoint": "GET /api/assets",
            "error_handling": "Global interceptor"
          },
          {
            "name": "useAssetArchiveCounts",
            "queryKey": "['asset-archive-counts']",
            "endpoints": [
              "GET /api/assets?showArchived=false&page=1&pageSize=1",
              "GET /api/assets?showArchived=true&page=1&pageSize=1"
            ],
            "staleTime": "30_000 (30 seconds)",
            "returns": "{ active: number, archived: number }"
          },
          {
            "name": "useAsset",
            "queryKey": "['assets', 'detail', id]",
            "endpoint": "GET /api/assets/{id}",
            "options": "enabled: id truthy, refetchOnMount: 'always', staleTime: 0",
            "error_handling": "Global interceptor"
          },
          {
            "name": "useAddAsset",
            "mutationFn": "POST /api/assets",
            "onSuccess_invalidateQueries": [
              "['assets'] (all asset queries)",
              "['asset-archive-counts']",
              "['notifications']"
            ],
            "onSuccess_toast": "Asset added successfully",
            "onError_toast": "parseApiError(..., 'Failed to add asset')"
          },
          {
            "name": "useUpdateAsset",
            "mutationFn": "PUT /api/assets/{id}",
            "onSuccess_invalidateQueries": [
              "['assets']",
              "['asset-archive-counts']",
              "['assets', 'detail', variables.id]"
            ],
            "onSuccess_toast": "Asset updated successfully",
            "onError_toast": "parseApiError(...)"
          },
          {
            "name": "useArchiveAsset",
            "mutationFn": "PUT /api/assets/{id}/archive",
            "cache_invalidation": "Same as useUpdateAsset",
            "error_handling": "Sonner toast on axios errors"
          }
        ]
      },
      {
        "file": "use-rooms.ts",
        "exports": [
          {
            "name": "useRooms",
            "queryKey": "['rooms', showArchived]",
            "endpoint": "GET /api/rooms",
            "error_handling": "Global interceptor"
          },
          {
            "name": "useAddRoom",
            "mutationFn": "POST /api/rooms",
            "onSuccess_invalidateQueries": ["['rooms']"],
            "onSuccess_toast": "Room added successfully",
            "onError_handling": "409 (axios) → display error.response.data.message or 'Room already exists'"
          },
          {
            "name": "useUpdateRoom",
            "mutationFn": "PUT /api/rooms/{id}",
            "onSuccess_invalidateQueries": ["['rooms']"],
            "onSuccess_toast": "Room updated successfully",
            "onError_toast": "Failed to update room"
          },
          {
            "name": "useArchiveRoom",
            "mutationFn": "PATCH /api/rooms/{id}/archive",
            "onSuccess_invalidateQueries": ["['rooms']"],
            "onSuccess_toast": "Room archived",
            "onError_handling": "409 (axios) → error.response.data.message or 'Failed to archive room.'"
          },
          {
            "name": "useRestoreRoom",
            "mutationFn": "PATCH /api/rooms/{id}/restore",
            "onSuccess_invalidateQueries": ["['rooms']"],
            "onSuccess_toast": "Room restored",
            "onError_toast": "Failed to restore room"
          },
          {
            "name": "useRoomCategories",
            "queryKey": "['room-categories', showArchived]",
            "endpoint": "GET /api/roomcategories"
          },
          {
            "name": "useArchiveRoomCategory",
            "mutationFn": "PATCH /api/roomcategories/{id}/archive",
            "queryConfig": "{ suppressGlobalError: true }",
            "onSuccess_toast": "Shows response.message",
            "response_type": "{ message?, cascadedRoomCount?, cascadedSubCategoryCount? }",
            "error_handling": "409 handled via onError callback"
          }
        ]
      },
      {
        "file": "use-maintenance.ts",
        "exports": [
          {
            "name": "useMaintenanceRecords",
            "queryKey": "['maintenance', showArchived]",
            "endpoints": "['/api/maintenance', '/api/maintenance-records', '/api/maintenance-manager'] (fallback loop)",
            "staleTime": "120_000 (2 minutes) - list payloads are large",
            "error_handling": "404 tries next endpoint; other errors thrown"
          },
          {
            "name": "useAllocatedAssetsForMaintenance",
            "queryKey": "['maintenance', 'allocated-assets']",
            "endpoint": "GET /api/maintenance/allocated-assets",
            "response_safety": "asArray<T>(data) guard handles non-array responses"
          },
          {
            "name": "useAddMaintenanceRecord",
            "mutationFn": "POST /api/maintenance (with CreateMaintenancePayload)",
            "idempotency_key": "scheduleSeriesId (client-generated); resubmit → 409 after first success",
            "onSuccess_invalidateQueries": [
              "['maintenance']",
              "['maintenance', 'allocated-assets']",
              "['notifications']"
            ],
            "onSuccess_toast": "Maintenance record created",
            "batch_response": "CreateMaintenanceBatchResponse { items, count }"
          }
        ]
      },
      {
        "file": "use-procurement.ts",
        "exports": [
          {
            "name": "usePurchaseOrders",
            "queryKey": "['purchaseOrders', showArchived]",
            "endpoint": "GET /api/PurchaseOrders"
          },
          {
            "name": "useCreateOrder",
            "mutationFn": "POST /api/PurchaseOrders",
            "onSuccess_invalidateQueries": ["['purchaseOrders']"],
            "onSuccess_toast": "Procurement order initiated",
            "onError_toast": "error.response?.data?.message or 'Failed to create procurement order'"
          },
          {
            "name": "useReceiveOrder",
            "mutationFn": "PUT /api/PurchaseOrders/{id}/receive",
            "body": "{ deliveryDate, categoryId? }",
            "onSuccess_invalidateQueries": [
              "['purchaseOrders']",
              "['assets']"
            ],
            "onSuccess_toast": "Purchase order received. Asset created.",
            "onError_toast": "Failed to receive order"
          }
        ]
      }
    ],
    "global_react_query_config": {
      "file": "src/components/query-provider.tsx",
      "QueryClient_defaultOptions": {
        "queries": {
          "staleTime": "60 * 1000 (1 minute)",
          "retry": "1 (retry once on failure)",
          "refetchOnWindowFocus": "false"
        }
      },
      "note": "Individual hooks can override staleTime (e.g., useMaintenanceRecords: 120_000, useAssetArchiveCounts: 30_000)"
    },
    "cache_invalidation_strategy": [
      "POST/PUT/PATCH mutations call queryClient.invalidateQueries({ queryKey: [...] })",
      "Pattern 1: Single entity cache - invalidate broad queryKey (e.g., ['assets']) to update all derivative queries",
      "Pattern 2: Specific detail cache - also invalidate ['assets', 'detail', id] to refresh individual asset view",
      "Pattern 3: Related caches - invalidate ['asset-archive-counts'] when asset archived/restored",
      "Note: logout() in auth-context does NOT explicitly call queryClient.clear(); browser refresh required for full cache clear"
    ]
  },

