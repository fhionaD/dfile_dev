# ─── .NET build artifacts ────────────────────────────────────────
DFile.backend/bin/
DFile.backend/obj/
DFile.backend/publish/
DFile.backend/artifacts/
DFile.backend/_build_verify/

# ─── Backend wwwroot (generated by `npm run build` postbuild step)
# These are frontend build outputs — do NOT commit them.
# GitHub Actions rebuilds them fresh from DFile.frontend/out/ on every deploy.
DFile.backend/wwwroot/

# ─── Runtime uploads (maintenance attachments, etc.)
DFile.backend/uploads/

# ─── Root-level publish output (generated by `dotnet publish`)
publish/

# ─── Next.js build output ────────────────────────────────────────
DFile.frontend/.next/
DFile.frontend/out/

# ─── Node modules ────────────────────────────────────────────────
**/node_modules/

# ─── Environment & secrets ───────────────────────────────────────
.env
.env.local
.env.*.local

# Development appsettings contain real credentials — use dotnet user-secrets instead.
# See: https://learn.microsoft.com/en-us/aspnet/core/security/app-secrets
DFile.backend/appsettings.Development.json

# ─── OS / editor ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.user
*.suo
.vs/
