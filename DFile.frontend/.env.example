# Optional: allow `npm run dev` from another device on your LAN (Next blocks by default).
# ALLOWED_DEV_ORIGINS=192.168.1.44
#
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL — Backend root for API calls (no "/api" suffix)
# ---------------------------------------------------------------------------
#
# RECOMMENDED when you open the app from Kestrel after `dotnet run`
# (static export copied to wwwroot — same host as the API, e.g. http://localhost:5090):
#   Leave this UNSET or empty. The client will call /api/... on the same origin.
#
NEXT_PUBLIC_API_URL=
#
# `npm run dev` on http://localhost:3000: leave empty — the browser calls /api on :3000 and
# next.config.ts rewrites those requests to http://localhost:5090 (Kestrel must be running).
#
# Use an explicit URL only when the API is on a different machine or non-default host, e.g.:
#   NEXT_PUBLIC_API_URL=http://192.168.1.10:5090
#
# NEXT_PUBLIC_API_URL=http://localhost:5090
#
# Production API on another host (host only, never end with /api):
# NEXT_PUBLIC_API_URL=https://api.myapp.com
# ---------------------------------------------------------------------------
